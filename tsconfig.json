{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ESNext"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "typeRoots": [
      "./web/node_modules/@types",
      "./cli/node_modules/@types",
      "./common/node_modules/@types"
    ],

    "noEmit": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "paths": {
      "@/*": ["./web/*"]
    }
  },
  "include": [
    "common/**/*.ts",
    "cli/src/**/*.ts",
    "web/**/*.ts",
    "web/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules",
    "**/.next",
    "**/styled-system",
    "**/dist"
  ]
}
