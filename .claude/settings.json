{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath'); echo \"$f\" | grep -q 'common/index\\.ts$' && bun common/schema.ts 2>/dev/null || true",
            "statusMessage": "Regenerating JSON schema..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  }
}
