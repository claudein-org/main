#!/usr/bin/env sh

NULL_SHA="0000000000000000000000000000000000000000"
REMOTE="$1"

while IFS=' ' read -r local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_ref" != "refs/heads/main" ]; then
    continue
  fi

  if [ "$remote_oid" = "$NULL_SHA" ]; then
    BASE="$(git rev-list --max-parents=0 HEAD)"
  else
    BASE="$remote_oid"
  fi

  if git diff --name-only "$BASE" "$local_oid" | grep -qE '^(cli|common)/'; then
    (cd cli && bun pm version patch --no-git-tag-version)
    git add cli/package.json
    git commit --no-verify -m "chore: bump cli version"
    git push --no-verify "$REMOTE" HEAD:main
  fi

  break
done
